/* CHECK.6.1 DEEPER FOCUS ON ATECO2=68 - ATTIVITA' IMM. */

data att_imm_score25_missing;
set stability_check_ateco;
	where 
/* casistica acuto */
	(SINTESI_ACUTO_BASE_25 = . and 
		SINTESI_ACUTO_BASE_24 ne .) or
/* casistica trasizione */
		(RT_DECO_PRENOTCH_25 = . and
		RT_DECO_PRENOTCH_24 ne .) or
/* casistica atmosfera */
		(DEP_ATMOSFERA_25 = . and 
		DEP_ATMOSFERA_24 ne .);
run;

/* Intreccio di casistiche dove score 2024 valorizzato, mentre socre 2025 missing */
proc sql;
	create table att_imm_score25_missing_fl
	as select
		*
		,case
			when (SINTESI_ACUTO_BASE_25 = . and SINTESI_ACUTO_BASE_24 ne .) then 1
			else 0 end as fl_fisico
		,case
			when (RT_DECO_PRENOTCH_25 = . and RT_DECO_PRENOTCH_24 ne .) then 1
			else 0 end as fl_transizione
		,case
			when (DEP_ATMOSFERA_25 = . and DEP_ATMOSFERA_24 ne .) then 1
			else 0 end as fl_atmosfera
	from att_imm_score25_missing;
quit;


proc freq data=att_imm_score25_missing_fl;
table fl_fisico*fl_transizione*fl_atmosfera / list missing nocum out=freq;
run;

