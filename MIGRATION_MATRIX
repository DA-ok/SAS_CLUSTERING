/* CHECK.4 - Spostamenti tra Dic24 e Dic25 */
/* COSTRUZIONE MATRICI DI MIGRAZIONE */

data crif_2024;
set aggancio_esposizione;
where datepart(dat_flusso)="31DEC2024"d;
run;

data crif_2025;
set aggancio_esposizione;
where datepart(dat_flusso)="31DEC2025"d;
run;

/* seleziono ogni score nei due anni diversi(ho creato due db nello step precedente) e aggiungo il suffisso dell'anno di appartenenza */
%macro list_iteration(list=, prefix=, suffix=);

	%local i var stem; /* CREATE IN LOCAL 3 VAR - i var stem */
	%do i=1 %to %sysfunc(countw(&list., %str( )));
		%let var=%scan(&list., &i., %str( ));
		%let stem = %substr(&var.,11,26);
		&prefix.&var. as &stem.&suffix. /* PREFIX IS NEDEED TO POINT THE DBs FOR THE JOIN */
		%if &i. < %sysfunc(countw(&list., %str( ))) %then ,;
	%end;
%mend;

/* creati gli score _25 e _24, creo la variabile delta per individuare eventuali delta (per ogni score) */
%macro shift_iteration(list=, suf1=_24, suf2=_25);

	%local i v stem;
	%do i=1 %to %sysfunc(countw(&list., %str( )));
		%let v = %scan(&list.,&i.);
		%let stem = %substr(&v.,11,26);

		(&stem.&suf2. - &stem.&suf1.) as SHIFT_&stem.
		%if &i < %sysfunc(countw(&list.)) %then ,;
	%end;
%mend;

/* aggancio tutto in un unico db */
proc sql;
	create table stability_check as
	select
		a.cod_banca
		,a.cod_anag
		,coalesce(b.ATECO2, a.ATECO2) as ATECO2
		,a.des_note as NOTA_24
		,b.des_note as NOTA_25
		,%list_iteration(list=&rischi_ce., prefix=a., suffix=_24)
		,%list_iteration(list=&rischi_ce., prefix=b., suffix=_25)
		,%shift_iteration(list=&rischi_ce.)
	from crif_2024 as a
		inner join crif_2025 as b
		on a.cod_banca = b.cod_banca
		and a.cod_anag = b.cod_anag;
quit;

/* sub-db contentente soltanto le ctp per le quali almeno uno score si è modificato tra 24 e 25 */
data check;
set stability_check;
	array shifts {*} SHIFT_:;
    do i = 1 to dim(shifts);
        if shifts{i} > 0 then output;
    end;

    drop i;
run;

/* Per ogni rischio, livello di spostamento tra 2024vs2025:
alias, quanti cambiano score e di quanto cambia */
%macro shift_magnitude(list=);
	%local i v stem n;
	%let n = %sysfunc(countw(&list., %str( )));

	%do i=1 %to &n.;
		%let v    = %scan(&list., &i., %str( ));
		%let stem = %substr(&v.,11);

		proc freq data=stability_check;
			tables SHIFT_&stem. / list missing nocum
			out=freq_SHIFT_&stem.;
		run;

	%end;
%mend;

%shift_magnitude(list=&rischi_ce.);

/* CHECK.5 Analisi di Stabilità - ctp che cambiano score */
%macro migration_matrix(list=);

	%local i v stem n;
	%let n = %sysfunc(countw(&list., %str( )));

	%do i=1 %to &n.;
		%let v    = %scan(&list., &i., %str( ));
		%let stem = %substr(&v.,11);

		proc freq data=stability_check noprint;
			tables &stem._24 * &stem._25
				/ missing
				out=mig_&stem. (drop=percent);
		run;

	%end;
%mend;

%migration_matrix(list=&rischi_ce.);
/* casistiche da evidenziare:
- ctp con score 2024 missing -> score 2025 valorizzato 
- ctp con score 2025 missing -> score 2024 valorizzato 
Numeriche variano in base al rischio in considerazione */

proc sort data=&lib_mapping..&db_mapping. nodupkey out=db_mapping_ateco_2;
by 'Descrizione Codice Ateco 2 digit'n 'Codice Ateco 2 digits'n;
run;

proc sql;
	create table stability_check_ateco
	as select
		a.*
		,b.'Descrizione Codice Ateco 2 digit'n as DES_ATECO2
		,case
			when ateco is null then 0
			else 1 end as fl_agg
	from stability_check as a
		left join db_mapping_ateco_2 as b
		on a.ateco2 = b.'Codice Ateco 2 digits'n;
quit;

proc freq data=stability_check_ateco;
table fl_agg / list missing nocum out=check;
run;

