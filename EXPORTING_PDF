#!/usr/bin/env python
# coding: utf-8

# In[12]:


import pdfplumber # reading data from pdfs
import pandas as pd
import re 
from pathlib import Path # reading all the pdfs from inside the same path


# In[13]:


base_folder = Path("/Users/famiglia/Desktop/ALER/PDF")

output_base = Path("/Users/famiglia/Desktop/ALER/EXCEL")

rows = [] 

# Lista delle località in Lombardia 
localita_list = [ "MILANO", 
                  "CORSICO", 
                  "SESTO SAN GIOVANNI", 
                  "PIEVE EMANUELE", 
                  "LEGNANO", 
                  "ABBIATEGRASSO", 
                  "SAN DONATO MILANESE", 
                  "SAN DONATO MILANE" # aggiunta per il PDF 
                ]


# In[16]:


for pdf_path in base_folder.rglob("*.pdf"):

    year = pdf_path.parent.name

    if not year.isdigit():
        continue

    output_year_folder = output_base / year
    output_year_folder.mkdir(parents=True, exist_ok=True)

    output_path = output_year_folder / f"{pdf_path.stem}.xlsx"

    print(f"Processing: {pdf_path.name}")
    print(f"Output → {output_path}")

    rows = []

    with pdfplumber.open(pdf_path) as pdf:
        for page in pdf.pages:
            text = page.extract_text()
            if not text:
                continue

            lines = text.split("\n")
            for line in lines:
                line = line.strip()
                year_suffix = year[-2:]  # "2025" → "25"

                if not re.match(rf"^\s*\d+\/{year_suffix}", line):
                    continue

                line = re.sub(r"\s+", " ", line)

                words = line.split()
                lotto = words[0]
                codice = words[1]

                if len(words) > 2 and re.match(r"^\d+$", words[2]):
                    box = words[2]
                else:
                    box = "ASSENTE"

                localita = None
                localita_start = None
                for loc in localita_list:
                    match = re.search(r"\b" + re.escape(loc.upper()) + r"\b", line.upper())
                    if match:
                        localita = loc
                        localita_start = match.start()
                        break

                if not localita:
                    continue

                mq_match = re.search(r"\s(\d+)\s+€", line)
                mq = int(mq_match.group(1)) if mq_match else 0

                pre_mq_text = (
                    line[localita_start + len(localita):mq_match.start()].strip()
                    if mq_match else ""
                )
                pre_mq_words = pre_mq_text.split()

                civico = pre_mq_words[-1] if pre_mq_words else ""
                indirizzo = " ".join(pre_mq_words[:-1]) if pre_mq_words else ""

                euro_values = re.findall(r"€\s*[\d.,]+", line)
                base_asta = (
                    float(euro_values[0].replace("€","").replace(".","").replace(",","."))
                    if len(euro_values) > 0 else 0
                )
                offerta = (
                    float(euro_values[1].replace("€","").replace(".","").replace(",","."))
                    if len(euro_values) > 1 else 0
                )

                if "ASTA DESERTA" in line:
                    esito = "ASTA DESERTA"
                elif "ASTA NULLA" in line:
                    esito = "ASTA NULLA"
                else:
                    esito = "AGGIUDICATO"

                rows.append([
                    lotto, codice, box, localita, indirizzo, civico,
                    mq, base_asta, offerta, esito
                ])

    if rows:
        df = pd.DataFrame(rows, columns=[
            "Lotto", "Codice", "Box", "Località", "Indirizzo", "Civico",
            "MQ", "Base_Asta", "Offerta", "Esito"
        ])
        df.to_excel(output_path, index=False)
        print(f"✅ Created: {output_path.name} ({len(rows)} rows)")


