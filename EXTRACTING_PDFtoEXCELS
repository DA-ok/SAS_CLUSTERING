# VERSION 1 - EXTRACTING PDF IN EXCEL [2025 - 2024 - NOV2023]

import pdfplumber
import pandas as pd
import re

# Percorsi
pdf_path = "/Users/antoniodagosto/Desktop/CASA_MILANO/01.ALER/01.ASTE/01.PDF/2023/esito-23novembre2023.pdf"
output_path = "/Users/antoniodagosto/Desktop/CASA_MILANO/01.ALER/01.ASTE/02.EXCEL/2023/esito_23novembre2023.xlsx"

rows = []

# Lista delle località in Lombardia
localita_list = [
    "MILANO", 
    "CORSICO", 
    "SESTO SAN GIOVANNI",
    "PIEVE EMANUELE", 
    "LEGNANO", 
    "ABBIATEGRASSO",
    "SAN DONATO MILANESE",
    "SAN DONATO MILANE",   # aggiunta per il PDF
    "NERVIANO"
]

with pdfplumber.open(pdf_path) as pdf:
    for page in pdf.pages:
        text = page.extract_text()
        if not text:
            continue

        lines = text.split("\n")
        for line in lines:
            line = line.strip()
            if not re.match(r"^\s*\d+\/23", line):
                continue

            line = re.sub(r"\s+", " ", line)

            words = line.split()
            # Lotto e Codice
            lotto = words[0]
            codice = words[1]

            # BOX: se numero prendilo, altrimenti ASSENTE
            if len(words) > 2 and re.match(r"^\d+$", words[2]):
                box = words[2]
                start_idx = 3
            else:
                box = "ASSENTE"
                start_idx = 2

            # Trova la località nella riga (match substring)
            localita = None
            localita_start = None
            for loc in localita_list:
                match = re.search(r"\b" + re.escape(loc.upper()) + r"\b", line.upper())
                if match:
                    localita = loc
                    localita_start = match.start()
                    break

            if not localita:
                print("⚠️ Località non trovata:", line)
                continue

            # Trova MQ
            mq_match = re.search(r"\s(\d+)\s+€", line)
            mq = int(mq_match.group(1)) if mq_match else 0

            # Estrazione pre-MQ per indirizzo e civico
            pre_mq_text = line[localita_start + len(localita):mq_match.start()].strip() if mq_match else ""
            pre_mq_words = pre_mq_text.split()
            if pre_mq_words:
                civico = pre_mq_words[-1]
                indirizzo = " ".join(pre_mq_words[:-1])
            else:
                civico = ""
                indirizzo = ""

            # Valori monetari
            euro_values = re.findall(r"€\s*[\d.,]+", line)
            base_asta = float(euro_values[0].replace("€","").replace(".","").replace(",",".").strip()) if len(euro_values) > 0 else 0.0
            offerta = float(euro_values[1].replace("€","").replace(".","").replace(",",".").strip()) if len(euro_values) > 1 else 0.0

            # Esito
            if "ASTA DESERTA" in line:
                esito = "ASTA DESERTA"
            elif "ASTA NULLA" in line:
                esito = "ASTA NULLA"
            else:
                esito = "AGGIUDICATO"

            # Aggiungi riga
            rows.append([
                lotto, codice, box, localita, indirizzo, civico,
                mq, base_asta, offerta, esito
            ])

# Creazione DataFrame
columns = [
    "Lotto", "Codice", "Box", "Località", "Indirizzo", "Civico",
    "MQ", "Base_Asta", "Offerta", "Esito"
]
df = pd.DataFrame(rows, columns=columns)

# Esportazione Excel
df.to_excel(output_path, index=False)

print(f"✅ File Excel creato con successo in: {output_path}")
print(f"✅ Numero righe elaborate: {len(rows)}")
